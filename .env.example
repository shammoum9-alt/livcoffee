# Copier ce fichier vers .env et renseigner les vraies valeurs.
# .env ne doit JAMAIS être commité (il est dans .gitignore).
#
# Ces valeurs se trouvent dans Supabase → Settings → API.
# La clé "anon/publishable" est faite pour être exposée côté client — ce n'est
# pas un secret au sens strict, mais elle ne doit pas non plus être versionnée
# en clair dans l'historique Git (bonnes pratiques + rotation facile si besoin).

REACT_APP_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
REACT_APP_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
